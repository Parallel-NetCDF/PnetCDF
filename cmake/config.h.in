/*
 * Simplified CMake-generated configuration for the core C MPI-IO build.
 * This intentionally covers the symbols used by the core library path only.
 */
#ifndef H_CONFIG
#define H_CONFIG

#cmakedefine HAVE_ACCESS 1
#cmakedefine HAVE_CLOSE 1
#cmakedefine HAVE_LSTAT 1
#cmakedefine HAVE_OPEN 1
#cmakedefine HAVE_STAT 1
#cmakedefine HAVE_STATFS 1
#cmakedefine HAVE_STATVFS 1
#cmakedefine HAVE_STRERROR 1
#cmakedefine HAVE_STDLIB_H 1
#cmakedefine HAVE_SYS_MOUNT_H 1
#cmakedefine HAVE_SYS_PARAM_H 1
#cmakedefine HAVE_SYS_STAT_H 1
#cmakedefine HAVE_SYS_STATVFS_H 1
#cmakedefine HAVE_SYS_TYPES_H 1
#cmakedefine HAVE_SYS_VFS_H 1
#cmakedefine HAVE_UNISTD_H 1
#cmakedefine HAVE_UNLINK 1
#cmakedefine WORDS_BIGENDIAN 1
#cmakedefine FLOAT_WORDS_BIGENDIAN 1

#cmakedefine HAVE_PTRDIFF_T 1
#cmakedefine HAVE_UCHAR 1
#cmakedefine HAVE_UINT 1
#cmakedefine HAVE_USHORT 1
#cmakedefine HAVE_LONGLONG 1
#cmakedefine HAVE_ULONGLONG 1
#cmakedefine HAVE_INT64 1
#cmakedefine HAVE_UINT64 1

#cmakedefine HAVE_MPI_COMBINER_DARRAY 1
#cmakedefine HAVE_MPI_COMBINER_DUP 1
#cmakedefine HAVE_MPI_COMBINER_HINDEXED_BLOCK 1
#cmakedefine HAVE_MPI_COMBINER_HINDEXED_INTEGER 1
#cmakedefine HAVE_MPI_COMBINER_HVECTOR_INTEGER 1
#cmakedefine HAVE_MPI_COMBINER_INDEXED_BLOCK 1
#cmakedefine HAVE_MPI_COMBINER_STRUCT_INTEGER 1
#cmakedefine HAVE_MPI_COMBINER_SUBARRAY 1
#cmakedefine HAVE_MPI_GET_COUNT_C 1
#cmakedefine HAVE_MPI_LARGE_COUNT 1
#cmakedefine HAVE_MPI_STATUSES_IGNORE 1
#cmakedefine HAVE_MPI_TYPE_SIZE_C 1
#cmakedefine HAVE_MPI_TYPE_SIZE_X 1
#cmakedefine HAVE_DECL_MPI_OFFSET 1

#define ENABLE_CXX 0
#define ENABLE_FORTRAN 0
#define OFFFMT "@MPI_OFFSET_FMT@"
#define PNETCDF_PROFILING @PNETCDF_PROFILING@

#define SIZEOF_CHAR @SIZEOF_CHAR@
#define SIZEOF_SIGNED_CHAR @SIZEOF_SIGNED_CHAR@
#define SIZEOF_UNSIGNED_CHAR @SIZEOF_UNSIGNED_CHAR@
#define SIZEOF_SHORT @SIZEOF_SHORT@
#define SIZEOF_UNSIGNED_SHORT @SIZEOF_UNSIGNED_SHORT@
#define SIZEOF_UNSIGNED_SHORT_INT @SIZEOF_UNSIGNED_SHORT_INT@
#define SIZEOF_INT @SIZEOF_INT@
#define SIZEOF_UNSIGNED_INT @SIZEOF_UNSIGNED_INT@
#define SIZEOF_LONG @SIZEOF_LONG@
#define SIZEOF_FLOAT @SIZEOF_FLOAT@
#define SIZEOF_DOUBLE @SIZEOF_DOUBLE@
#define SIZEOF_LONG_LONG @SIZEOF_LONG_LONG@
#define SIZEOF_UNSIGNED_LONG_LONG @SIZEOF_UNSIGNED_LONG_LONG@
#define SIZEOF_OFF_T @SIZEOF_OFF_T@
#define SIZEOF_PTRDIFF_T @SIZEOF_PTRDIFF_T@
#define SIZEOF_SIZE_T @SIZEOF_SIZE_T@
#define SIZEOF_MPI_AINT @SIZEOF_MPI_AINT@
#define SIZEOF_MPI_COUNT @SIZEOF_MPI_COUNT@
#define SIZEOF_MPI_OFFSET @SIZEOF_MPI_OFFSET@
#define SIZEOF_MPI_LONG_LONG_INT @SIZEOF_LONG_LONG@

#define SIZEOF_BYTE @SIZEOF_SIGNED_CHAR@
#define SIZEOF_UBYTE @SIZEOF_UNSIGNED_CHAR@
#define SIZEOF_UCHAR @SIZEOF_UNSIGNED_CHAR@
#define SIZEOF_USHORT @SIZEOF_UNSIGNED_SHORT@
#define SIZEOF_UINT @SIZEOF_UNSIGNED_INT@
#define SIZEOF_ULONG @SIZEOF_LONG@
#define SIZEOF_LONGLONG @SIZEOF_LONG_LONG@
#define SIZEOF_ULONGLONG @SIZEOF_UNSIGNED_LONG_LONG@
#define SIZEOF_INT64 @SIZEOF_LONG_LONG@
#define SIZEOF_UINT64 @SIZEOF_UNSIGNED_LONG_LONG@

#include <nctypes.h>
#endif
